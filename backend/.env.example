# ---------------------------------------------------------------------------
# BioStoreX Backend - environment variables
# Copy this file to .env and fill in real values. Never commit your .env file.
# ---------------------------------------------------------------------------

# Server
PORT=8000
NODE_ENV=development
# Comma-separated list of allowed frontend origins (no trailing slashes)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# MongoDB (the DB name "BioStoreX" is appended automatically; do not include it here)
MONGODB_URI=mongodb://127.0.0.1:27017

# Auth - generate strong random secrets, e.g. `openssl rand -hex 32`
ACCESS_TOKEN_SECRET=change-this-access-secret
ACCESS_TOKEN_EXPIRY=1d
REFRESH_TOKEN_SECRET=change-this-refresh-secret
REFRESH_TOKEN_EXPIRY=10d

# Cloudinary (item images)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Default Admin auto-seeded on first server start (only if no Admin exists yet).
# Leave blank to skip auto-seeding and create the admin manually instead.
DEFAULT_ADMIN_EMAIL=
DEFAULT_ADMIN_PASSWORD=
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_FULLNAME=System Administrator

# Optional default Storekeeper auto-seeded on first server start.
# Existing storekeeper accounts are never overwritten by this startup helper.
DEFAULT_STOREKEEPER_EMAIL=
DEFAULT_STOREKEEPER_PASSWORD=
DEFAULT_STOREKEEPER_USERNAME=
DEFAULT_STOREKEEPER_FULLNAME=

# AI features (chatbot, smart search, restock insights, item description generation)
# Prefer Groq for this project, or set OpenAI variables instead. Leave both
# keys blank to disable model-generated AI summaries/chat while deterministic
# inventory analytics still work.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Email via Resend (optional - used for password-reset OTPs; if unset, OTPs are logged to the server console instead)
RESEND_API_KEY=
FROM_EMAIL=your_verified_email@yourdomain.com
